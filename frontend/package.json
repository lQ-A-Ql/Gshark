{
  "name": "@gshark/sentinel-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:wails": "vite build && powershell -ExecutionPolicy Bypass -File ../scripts/build-backend-binary.ps1",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run size:check && pnpm run test:run && pnpm run build",
    "format:check": "prettier --check \"eslint.config.js\" \"scripts/**/*.mjs\" \"src/app/integrations/clients/**/*.{ts,tsx}\" \"src/app/integrations/mappers/**/*.{ts,tsx}\" \"src/app/state/captureConstants.ts\" \"src/app/state/progressHelpers.ts\" \"src/app/state/progressStatus*.ts\" \"src/app/state/backendStatusMessage*.ts\" \"src/app/state/captureSignal*.ts\" \"src/app/state/recentCaptures.ts\" \"src/app/state/sentinelTypes.ts\" \"src/app/state/streamState*.ts\" \"src/app/state/streamPrefetchPlan*.ts\" \"src/app/state/streamProtocol*.ts\" \"src/app/state/packetPagination*.ts\" \"src/app/state/selectedPacketState*.ts\" \"src/app/state/hooks/useSelectedPacketArtifact*.ts\" \"src/app/state/hooks/useSelectedPacketDetail*.ts\" \"src/app/misc/FilterActions.tsx\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "preview": "vite preview",
    "size:check": "node scripts/check-size.mjs",
    "test": "vitest run",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit --noUnusedLocals --noUnusedParameters"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "pako": "^2.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "2.1.7",
    "react-router": "7.13.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "24.3.0",
    "@types/pako": "^2.0.4",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "tailwindcss": "4.1.12",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.46.4",
    "vite": "6.3.5",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
